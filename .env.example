# Copia este archivo como .env y completa los valores reales
# El archivo .env está en .gitignore y NO se sube al repositorio

# Clave secreta de Django (genera una nueva en producción)
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion

# Modo depuración (True para desarrollo, False para producción)
DEBUG=True

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuración de correo electrónico
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_de_aplicacion

# Correos para notificaciones
ADMIN_EMAIL=correo_destino@gmail.com
NOTIFICATION_FROM_EMAIL=tu_correo@gmail.com
